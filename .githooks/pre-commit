#!/bin/sh
# Refuse a direct commit onto main — every change goes through a branch/worktree + PR
# instead (see CLAUDE.md, and main's own GitHub branch protection, which enforces the
# same rule server-side). This is the local half: it catches the mistake before you've
# even tried to push. Wired in via core.hooksPath (see package.json's "prepare" script),
# so it applies the moment you `npm install`, no manual setup needed.
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo "✗ refusing to commit directly to main." >&2
  echo "  Create a branch or worktree for this change instead." >&2
  echo "  Genuine exception: git commit --no-verify" >&2
  exit 1
fi
