node_modules/
dist/
*.log
.DS_Store
.claude/
hi-chu-*.zip

# The optimized demo GIF (demo/hichu-demo.gif) IS committed so the README renders
# it reliably; intermediate/large recordings are not.
demo/*.mp4
demo/*-raw.gif

# Chrome Web Store upload assets (generated; not repo content)
store-screenshots/

# `npm run screenshots` output — candidate shots from a throwaway battle; the keepers
# get copied into demo/ and store-screenshots/ by hand.
screenshots/

# The self-hosted Showdown server `player-check`/`screenshots` battle against (see
# scripts/lib/local-server.mjs) — cloned + npm installed on first run, not repo content.
.ps-server/

# Xcode's own build cache for the Safari port (safari/hi-chu/) — regenerable, huge,
# machine-specific; the Xcode project source itself is tracked.
safari/build/
