{
  "name": "hi-chu",
  "version": "0.18.0",
  "description": "hi-chu: Pokémon Showdown random-battle tooltips with per-move damage, true multi-hit KO%, and reveal-narrowed set possibilities.",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "node scripts/package.mjs",
    "icons": "node scripts/make-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test",
    "drift-check": "node scripts/drift-check.mjs",
    "player-check": "node scripts/player-check.mjs",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "@smogon/calc": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "puppeteer-core": "^25.3.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
