{
  "manifest_version": 3,
  "name": "hi-chu",
  "version": "0.9.0",
  "description": "Random Battle helpers on hover for Pokémon Showdown: possible sets, live-aware damage, and true multi-hit KO%.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://pkmn.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
