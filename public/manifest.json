{
  "manifest_version": 3,
  "name": "hi-chu",
  "version": "0.19.3",
  "description": "Pokémon Showdown battle hints: live-aware damage and multi-hit KO% in every format, plus Random Battle set possibilities.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://pkmn.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
